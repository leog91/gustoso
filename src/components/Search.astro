---
import search from "../assets/search.svg";
---

<div id="search-root" class="relative w-full max-w-xl">
  <form
    id="search-form"
    class="grid grid-cols-[1fr_auto] border border-black bg-white"
    role="search"
  >
    <input
      class="min-w-0 px-3 py-3 text-sm text-black placeholder:text-neutral-500 focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-black"
      placeholder="Search recipes"
      autocomplete="off"
      id="search"
      required
      name="search"
      aria-label="Search recipes"
    />
    <button class="border-l border-black px-3 hover:bg-black hover:text-white focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-black" aria-label="Search recipes">
      <img class="size-4" src={search.src} alt="" />
    </button>
  </form>
  <div
    id="results"
    class="absolute z-10 mt-2 hidden w-full border border-black bg-white"
    role="status"
    aria-live="polite"
  >
    <ul id="results-list"></ul>
  </div>
</div>

<script>
  import { actions } from "astro:actions";

  const form = document.getElementById("search-form");
  const input = document.getElementById("search") as HTMLInputElement | null;
  const searchRoot = document.getElementById("search-root");
  const resultsWrapper = document.getElementById("results");
  const resultsList = document.getElementById("results-list");

  document.addEventListener("click", function (event) {
    if (
      resultsWrapper &&
      event.target instanceof Node &&
        !searchRoot?.contains(event.target)
    ) {
      resultsWrapper.classList.add("hidden");
    }
  });

  document.addEventListener("keydown", function (event) {
    if (event.key === "Escape") {
      resultsWrapper?.classList.add("hidden");
    }
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form) return;

    const formData = new FormData(form);
    const filteredRecipes = await actions.search(formData);

    if (resultsList) {
      resultsList.innerHTML = "";
    }

    if (!filteredRecipes.data || filteredRecipes.data.length === 0) {
      resultsWrapper?.classList.add("hidden");
      return;
    }

    filteredRecipes.data.forEach((r) => {
      const li = document.createElement("li");

      const a = document.createElement("a");
      a.href = "/recipes/" + r.item.url;
      a.textContent = r.item.title ?? r.item.url ?? "Unnamed Recipe";
      a.classList.add(
        "block",
        "border-b",
        "border-neutral-200",
        "px-3",
        "py-3",
        "text-sm",
        "font-bold",
        "uppercase",
        "tracking-[-0.02em]",
        "text-black",
        "hover:bg-[#C0392B]",
        "hover:text-white",
        "focus-visible:outline-2",
        "focus-visible:outline-offset-[-2px]",
        "focus-visible:outline-black"
      );

      li.appendChild(a);
      resultsList?.appendChild(li);
    });

    // Show results
    resultsWrapper?.classList.remove("hidden");
  });
</script>
