---
import { getCollection } from "astro:content";

const isDev = import.meta.env.DEV;

interface Props {
  selectedCategory?: string;
}

const { selectedCategory } = Astro.props;

const recipes = (await getCollection("recipes"))
  .map((r) => {
    return {
      recipe: r.data,
      url: r.id,
      published: r.data.published,
    };
  })
  .filter((r) => r.published !== false)
  .filter((r) => isDev || !r.recipe.needsReview)
  .sort((a, b) => {
    const imageOrder = Number(Boolean(b.recipe.img)) - Number(Boolean(a.recipe.img));
    return imageOrder || a.recipe.title.localeCompare(b.recipe.title);
  });

const categories = [...new Set(recipes.flatMap((recipe) => recipe.recipe.type ? [recipe.recipe.type] : []))].sort((a, b) => a.localeCompare(b));
const visibleRecipes = selectedCategory
  ? recipes.filter((recipe) => recipe.recipe.type === selectedCategory)
  : recipes;
---

<main id="recipe-index" class="mx-auto max-w-6xl border-x border-neutral-200 bg-white text-black">
  <nav aria-label="Recipe categories" class="flex flex-wrap gap-x-5 gap-y-2 border-b border-neutral-200 px-4 py-4 sm:px-6">
    <a href="/" aria-current={selectedCategory ? undefined : "page"} class="text-[10px] font-bold uppercase tracking-[0.18em] text-black underline-offset-4 hover:text-[#C0392B] hover:underline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-black">All recipes {recipes.length}</a>
    {categories.map((category) => (
      <a href={`/?category=${encodeURIComponent(category)}`} aria-current={selectedCategory === category ? "page" : undefined} class="text-[10px] font-bold uppercase tracking-[0.18em] text-neutral-500 underline-offset-4 hover:text-[#C0392B] hover:underline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-black">{category} {recipes.filter((recipe) => recipe.recipe.type === category).length}</a>
    ))}
  </nav>

  <section>
    <header class="flex items-baseline justify-between border-b border-neutral-200 px-4 py-4 sm:px-6">
      <h2 class="text-lg font-black uppercase tracking-[-0.03em]">{selectedCategory ?? "All recipes"}</h2>
      <span class="text-[10px] font-bold uppercase tracking-[0.18em] text-neutral-500">{visibleRecipes.length} {visibleRecipes.length === 1 ? "recipe" : "recipes"}</span>
    </header>
    <div class="grid md:grid-cols-2">
      {visibleRecipes.map((r) => (
          <article class:list={["group border-b border-neutral-200 p-4 sm:p-6", r.recipe.needsReview && "border-l-4 border-l-yellow-500 bg-yellow-50"]}>
            <div class="grid gap-5 sm:grid-cols-[1fr_7rem]">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[10px] font-bold uppercase tracking-[0.18em] text-neutral-500">
                  {r.recipe.type && <span>{r.recipe.type}</span>}
                  {isDev && r.recipe.needsReview && <span class="text-yellow-700">Review required</span>}
                </div>
                <h3 class="mt-3 text-2xl font-black uppercase leading-[0.95] tracking-[-0.045em]">
                  <a href={`/recipes/${r.url}`} class="underline-offset-4 hover:text-[#C0392B] hover:underline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-black">{r.recipe.title}</a>
                </h3>
                {r.recipe.description && <p class="mt-3 max-w-md text-sm leading-6 text-neutral-700">{r.recipe.description}</p>}
                {r.recipe.serves && <p class="mt-4 text-[10px] font-bold uppercase tracking-[0.18em] text-neutral-500">Yield: {r.recipe.serves}</p>}
                {isDev && r.recipe.needsReview && (
                  <div class="mt-5 flex gap-3">
                    <button data-slug={r.url} data-action="approve" class="border border-green-700 px-3 py-2 text-[10px] font-bold uppercase tracking-[0.18em] text-green-800 hover:bg-green-700 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-black">Approve</button>
                    <button data-slug={r.url} data-action="discard" class="border border-red-700 px-3 py-2 text-[10px] font-bold uppercase tracking-[0.18em] text-red-800 hover:bg-red-700 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-black">Discard</button>
                  </div>
                )}
              </div>
              {r.recipe.img ? (
                <img src={r.recipe.img} alt="" class="aspect-square h-full w-full border border-neutral-200 object-cover" loading="lazy" />
              ) : (
                <div class="grid aspect-square grid-cols-4 border border-neutral-200" aria-hidden="true">
                  {Array.from({ length: 16 }).map((_, index) => <span class:list={["border-neutral-200", index % 4 !== 3 && "border-r", index < 12 && "border-b"]}></span>)}
                </div>
              )}
            </div>
          </article>
      ))}
    </div>
  </section>
</main>

{isDev && <script>
  import { actions } from "astro:actions";

  // Only attach handlers if there are dev-action buttons present
  document.addEventListener("click", async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-action]");
    if (!btn) return;

    const slug = btn.dataset.slug;
    const action = btn.dataset.action;
    if (!slug || !action) return;

    e.preventDefault();
    e.stopPropagation();

    try {
      if (action === "discard") {
        await actions.discardRecipe({ slug });
      } else if (action === "approve") {
        await actions.removeNeedsReview({ slug });
      }
      window.location.reload();
    } catch (err: any) {
      console.error("Action failed:", err);
      alert(err.message || "Action failed");
    }
  });
</script>}
