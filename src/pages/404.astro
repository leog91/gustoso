---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found | Gustoso">
  <div class="min-h-dvh flex flex-col items-center justify-center bg-neutral-900 text-gray-100">
    <div class="w-full max-w-2xl mx-auto px-6 py-12 text-center">
      <h1 class="text-4xl font-black uppercase tracking-tight text-white">
        404
      </h1>
      <p class="mt-4 text-lg text-neutral-400">
        We couldn't find that page.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex border border-white bg-white px-6 py-3 text-[11px] font-bold uppercase tracking-[0.18em] text-neutral-900 transition hover:border-[#C0392B] hover:bg-[#C0392B] hover:text-white"
      >
        Go back home
      </a>
    </div>
  </div>
</Layout>
