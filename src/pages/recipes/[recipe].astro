---
import Layout from "../../layouts/Layout.astro";
import leftArrow from "../../assets/left-arrow.svg";
import { getCollection, render } from "astro:content";
import type { RecipePart } from "../../types";

const isDev = import.meta.env.DEV;
const { recipe } = Astro.params;

const recipes = await getCollection("recipes");

let currentRecipe = recipes.find(
  (post) => post.id === recipe
);

// In production, needsReview recipes should 404
if (!isDev && currentRecipe?.data.needsReview) {
  currentRecipe = undefined;
}

if (!currentRecipe) {
  return new Response(null, { status: 404 });
}

const renderedRecipe = await render(currentRecipe);
const hasMarkdownNotes = Boolean(currentRecipe.body?.trim());
const recipeParts: RecipePart[] = currentRecipe.data.parts?.length
  ? currentRecipe.data.parts
  : [{
      ingredients: currentRecipe.data.ingredients,
      instructions: currentRecipe.data.instructions,
    }];
const capitalizeFirst = (value: string) =>
  value ? value.charAt(0).toUpperCase() + value.slice(1) : value;

const pageTitle = `${currentRecipe.data.title} | Gustoso`;
const pageDescription = currentRecipe.data.description ?? `Recipe for ${currentRecipe.data.title}.`;

const recipeJsonLd = {
  "@context": "https://schema.org",
  "@type": "Recipe",
  name: currentRecipe.data.title,
  description: currentRecipe.data.description,
  ...(currentRecipe.data.author ? { author: { "@type": "Person", name: currentRecipe.data.author } } : {}),
  ...(currentRecipe.data.img ? { image: currentRecipe.data.img } : {}),
  ...(currentRecipe.data.serves ? { recipeYield: currentRecipe.data.serves } : {}),
  recipeIngredient: recipeParts.flatMap((p) => p.ingredients || []),
  recipeInstructions:
    recipeParts.flatMap((p) =>
      (p.instructions || []).map((ins) => ({
        "@type": "HowToStep",
        text: ins.description,
        ...(ins.step ? { position: ins.step } : {}),
      }))
    ) || [],
};
---

<Layout title={pageTitle} description={pageDescription}>
  {recipeJsonLd && (
    <Fragment slot="head">
      <meta property="og:type" content="article" />
      <meta property="og:title" content={currentRecipe.data.title} />
      <meta
        property="og:description"
        content={currentRecipe.data.description || `Recipe for ${currentRecipe.data.title}.`}
      />
      <script
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(recipeJsonLd)}
      />
    </Fragment>
  )}
  <div class="min-h-dvh bg-white text-black">
    <article class="mx-auto max-w-6xl border-x border-neutral-200 bg-white">
          <header class="border-b border-neutral-200">
            <div class="flex items-center justify-between px-4 py-3 sm:px-6">
              <a
                href="/"
                class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.18em] text-black transition hover:text-[#C0392B]"
              >
                <img src={leftArrow.src} alt="Back to recipes" class="h-3.5 w-3.5" />
                Recipe Index
              </a>
              <div class="flex items-center gap-2">
                {isDev && currentRecipe.data.needsReview ? (
                  <>
                    <button
                      data-slug={recipe}
                      data-action="approve"
                      class="cursor-pointer border border-green-600 bg-green-600 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-white transition hover:bg-white hover:text-green-600"
                      aria-label="Approve recipe"
                    >
                      ✓ Approve
                    </button>
                    <button
                      data-slug={recipe}
                      data-action="discard"
                      class="cursor-pointer border border-red-600 bg-red-600 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-white transition hover:bg-white hover:text-red-600"
                      aria-label="Discard recipe"
                    >
                      🗑️ Discard
                    </button>
                  </>
                ) : null}
                <div class="text-[11px] font-bold uppercase tracking-[0.18em] text-black">
                  Gustoso
                </div>
              </div>
            </div>

            <div class="grid border-t border-neutral-200 lg:grid-cols-[1.15fr_0.85fr]">
              {currentRecipe.data.img ? (
                <div class="border-b border-neutral-200 lg:border-b-0 lg:border-r lg:border-neutral-200">
                  <img
                    src={currentRecipe.data.img}
                    alt={currentRecipe.data.title}
                    class="h-[260px] w-full object-cover sm:h-[360px] lg:h-full"
                  />
                </div>
              ) : (
                <div class="flex min-h-[260px] flex-col justify-between border-b border-neutral-200 bg-[#F5F5F5] p-6 sm:min-h-[360px] lg:border-b-0 lg:border-r lg:border-neutral-200">
                  <div class="flex items-start justify-between gap-4 text-[10px] font-bold uppercase tracking-[0.22em] text-neutral-400">
                    <span>Gustoso</span>
                    <span>Recipe</span>
                  </div>
                  <div class="grid grid-cols-6 border-y border-neutral-300" aria-hidden="true">
                    {Array.from({ length: 18 }).map((_, index) => (
                      <div class:list={["aspect-square border-neutral-300", index % 6 !== 5 && "border-r", index < 12 && "border-b"]}></div>
                    ))}
                  </div>
                </div>
              )}

              <div class="flex flex-col justify-between px-4 py-5 sm:px-6 sm:py-6">
                <div>
                  <div class="flex flex-wrap gap-x-4 gap-y-2 text-[10px] font-bold uppercase tracking-[0.22em] text-neutral-500">
                    {currentRecipe.data.type && <span>{currentRecipe.data.type}</span>}
                  </div>
                  <h1 class="mt-5 max-w-lg text-4xl font-black uppercase leading-none tracking-[-0.05em] text-black sm:text-5xl">
                    {currentRecipe.data.title}
                  </h1>
                  {currentRecipe.data.description && (
                    <p class="mt-5 max-w-md text-sm leading-6 text-neutral-700">
                      {currentRecipe.data.description}
                    </p>
                  )}
                </div>

                {currentRecipe.data.serves && (
                  <div class="mt-8 border-t border-neutral-200 pt-4">
                    <div class="text-[10px] font-bold uppercase tracking-[0.2em] text-neutral-500">
                      Yield
                    </div>
                    <div class="mt-1 text-2xl font-black uppercase leading-none">
                      {currentRecipe.data.serves}
                    </div>
                  </div>
                )}
              </div>
            </div>
          </header>

          <div class="px-4 py-6 sm:px-6 sm:py-8">
            {recipeParts.some((p) => p.ingredients?.length || p.instructions?.length) && (
              <section class="space-y-8">
                {recipeParts.map((p) => {
                  const hasIngredients = Boolean(p.ingredients && p.ingredients.length > 0);
                  const hasInstructions = Boolean(p.instructions && p.instructions.length > 0);

                  if (!hasIngredients && !hasInstructions) {
                    return null;
                  }

                  return (
                    <section class="border-t border-neutral-200 pt-4">
                      {p.name && (
                        <h2 class="mb-4 text-[11px] font-bold uppercase tracking-[0.2em] text-black">
                          {p.name}
                        </h2>
                      )}

                      <div class:list={["grid gap-8", hasIngredients && hasInstructions ? "lg:grid-cols-[0.9fr_1.1fr]" : "grid-cols-1"]}>
                        {hasIngredients && (
                          <div>
                            <div class="border-t border-black pt-3">
                              {p.name ? (
                                <h3 class="text-[13px] font-bold uppercase tracking-[0.14em] text-black">Ingredients</h3>
                              ) : (
                                <h2 class="text-[13px] font-bold uppercase tracking-[0.14em] text-black">Ingredients</h2>
                              )}
                            </div>
                            <ul class="mt-4 divide-y divide-neutral-200 border-y border-neutral-200">
                              {p.ingredients?.map((ingredient) => {
                                const quantityMatch = ingredient.match(/^((?:\+?\d[\d\s.,/-]*|½|¼|¾|\[Opcional\]|\(?\+?\d[\d\s.,/-]*)(?:\s*[a-zA-Z%°]+(?:\s+[a-zA-Z%°]+)*)?)(?:\s+de\s+|\s+)(.+)$/u);
                                const ingredientQty = quantityMatch ? quantityMatch[1].trim() : "";
                                const ingredientName = quantityMatch ? quantityMatch[2].trim() : ingredient;

                                return (
                                  <li class="grid grid-cols-[1fr_auto] gap-4 py-3 text-sm leading-5">
                                    <span class="pr-4 text-black">{capitalizeFirst(ingredientName)}</span>
                                    {ingredientQty ? (
                                      <span class="text-right text-[11px] font-medium uppercase tracking-[0.08em] text-neutral-500">
                                        {ingredientQty}
                                      </span>
                                    ) : null}
                                  </li>
                                );
                              })}
                            </ul>
                          </div>
                        )}

                        {hasInstructions && (
                          <div>
                            <div class="border-t border-black pt-3">
                              {p.name ? (
                                <h3 class="text-[13px] font-bold uppercase tracking-[0.14em] text-black">Method</h3>
                              ) : (
                                <h2 class="text-[13px] font-bold uppercase tracking-[0.14em] text-black">Method</h2>
                              )}
                            </div>
                            <ol class="mt-4 space-y-6">
                              {p.instructions?.map((ins, stepIndex) => (
                                <li class="relative border-t border-neutral-200 pt-4 pl-20">
                                  <span class="pointer-events-none absolute left-0 top-1 text-5xl font-black leading-none tracking-[-0.08em] text-neutral-200">
                                    {String(stepIndex + 1).padStart(2, "0")}
                                  </span>
                                  <p class="max-w-xl text-sm leading-6 text-black">
                                    {ins.description}
                                  </p>
                                </li>
                              ))}
                            </ol>
                          </div>
                        )}
                      </div>
                      {p.storage && (
                        <aside class="mt-6 border-l-2 border-black pl-4">
                          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-neutral-500">Storage</h3>
                          <p class="mt-2 text-sm leading-6 text-neutral-700">{p.storage}</p>
                        </aside>
                      )}
                    </section>
                  );
                })}
              </section>
            )}

            {(currentRecipe.data.storage || hasMarkdownNotes) && (
              <section class="mt-10 border-t border-neutral-200 pt-5">
                <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
                  {currentRecipe.data.storage && (
                    <div class="border-l-2 border-black pl-4">
                      <h2 class="text-[10px] font-bold uppercase tracking-[0.2em] text-neutral-500">Storage</h2>
                      <p class="mt-2 text-sm leading-6 text-neutral-700">{currentRecipe.data.storage}</p>
                    </div>
                  )}

                  {renderedRecipe && hasMarkdownNotes && (
                    <div class="recipe-content border-t border-black pt-3">
                      <h2 class="text-[13px] font-bold uppercase tracking-[0.14em] text-black">
                        Notes
                      </h2>
                      <div class="mt-4 text-sm leading-6 text-black">
                        <renderedRecipe.Content />
                      </div>
                    </div>
                  )}
                </div>
              </section>
            )}
          </div>
    </article>
  </div>
</Layout>

{isDev && <script>
  import { actions } from "astro:actions";

  document.addEventListener("click", async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-action]");
    if (!btn) return;

    const slug = btn.dataset.slug;
    const action = btn.dataset.action;
    if (!slug || !action) return;

    e.preventDefault();
    e.stopPropagation();

    try {
      if (action === "discard") {
        await actions.discardRecipe({ slug });
        window.location.href = "/";
      } else if (action === "approve") {
        await actions.removeNeedsReview({ slug });
        window.location.reload();
      }
    } catch (err: any) {
      console.error("Action failed:", err);
      alert(err.message || "Action failed");
    }
  });
</script>}

<style>
  :global(body) {
    font-family: Inter, Helvetica, Arial, sans-serif;
  }

  .recipe-content :global(p) {
    margin-top: 0.75rem;
  }

  .recipe-content :global(ul),
  .recipe-content :global(ol) {
    margin-top: 0.75rem;
    padding-left: 1rem;
  }

  .recipe-content :global(li) {
    margin-top: 0.35rem;
  }

  .recipe-content :global(a) {
    color: #c0392b;
  }
</style>
