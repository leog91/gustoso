---
import Layout from "../../layouts/Layout.astro";
import leftArrow from "../../assets/left-arrow.svg";
import { getCollection, render } from "astro:content";

const { recipe } = Astro.params;

export interface RecipeStep {
  step?: number;
  description: string;
}

interface RecipePart {
  name?:string
  ingredients?: string[];
  instructions?: RecipeStep[];
}

export interface Recipe {
  id: string;
  data: {
    title: string;
    img?: string;
    type?: string;
    author?: string;
    serves?: string;
    storage?: string;
    description?: string;
    parts: RecipePart[];
  };
}

const recipes = await getCollection("recipes");

const currentRecipe = recipes.find(
  (post) => post.id === recipe
);

const renderedRecipe = currentRecipe ? await render(currentRecipe) : null;
---

<Layout>
  <div
    class="flex flex-col bg-white text-neutral-900 max-w-2xl m-auto min-h-dvh "
  >
    <div class="flex mt-4 ml-4 mb-8 relative">
      <div class="text-center absolute font-semibold text-xl w-full max-w-2xl">
        {recipe}
      </div>
      <a href={`/`} class="absolute">
        <img src={leftArrow.src} alt="image description" />
      </a>
    </div>
    <div>
      {
        currentRecipe && (
          <div class="p-4 ">
            {currentRecipe.data.img && (
              <div class="flex justify-center mb-4">
                <img
                  src={currentRecipe.data.img}
                  class="w-full  aspect-auto rounded-xl "
                />
              </div>
            )}
             
            <div class="flex items-center justify-between">
              <h1 class=" mb-4 font-semibold text-2xl">
                {currentRecipe.data.title}
              </h1>
              <div>
                {currentRecipe.data.type && (
                  <div class="bg-stone-500 text-white rounded-xl px-2 ">
                    {currentRecipe.data.type}
                  </div>
                )}
              </div>
            </div>
            {currentRecipe.data.serves && (
              <p class="text-stone-500"> {currentRecipe.data.serves}</p>
            )}

            {currentRecipe.data.description && (
              <div> {currentRecipe.data.description}</div>
            )}

            {currentRecipe.data.parts &&
              currentRecipe.data.parts.map((p: RecipePart, i:number) => (
                <div class={`mb-4 pt-2 ${i===0?"border-t-0":"border-t-2"}`}>                
                  {p.name && 
                  <h2 class="font-semibold text-xl mb-1">{p.name}</h2>
                  }
                  {p.ingredients &&
                  <h2 class="font-semibold">Ingredients:</h2>
                  <ol>
                    {p.ingredients?.map((i) => (
                      <li class="pl-2"> • {i}</li>
                    ))}
                  </ol>
                  }
                  {p.instructions &&
                   <h2 class="font-semibold">Instructions:</h2>
                  <ol>
                    {p.instructions?.map((ins) => (
                      <li class="pl-2">
                        {ins.step ? `${ins.step} - ` : ""}
                        {ins.description}
                      </li>
                    ))}
                  </ol> 
                  }                  
                </div>
              ))}

            
            {currentRecipe.data.storage && (
              <>
                <h2 class="font-semibold">Storage:</h2>

                {currentRecipe.data.storage}
              </>
            )}
            <div class="content">
              {renderedRecipe && <renderedRecipe.Content />}
            </div>
          </div>
        )
      }
    </div>
  </div>
</Layout>
