---
import Search from "../components/Search.astro";
import Welcome from "../components/Welcome.astro";
import Layout from "../layouts/Layout.astro";

const isDev = import.meta.env.DEV;
---

<Layout>
  <div class="flex items-center">
    <h2 class="text-2xl font-bold pb-2 pl-2 sm:pl-5 shadow-lg">gustoso</h2>
    <div class="flex flex-col mx-2 justify-center items-center w-full">
      <Search />
    </div>
    {isDev ? (
      <a
        href="/dev/trash"
        class="mr-4 text-sm text-yellow-400 hover:text-yellow-300 transition shrink-0"
        title="View discarded recipes"
      >
        🗑️ Trash
      </a>
    ) : null}
  </div>

  <Welcome />
</Layout>
